{
  "name": "willitcocktail",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc -b --noEmit",
    "pipeline:export": "node data-pipeline/export_seed.mjs",
    "pipeline:build": "python3 data-pipeline/build_db.py",
    "pipeline:version": "node data-pipeline/emit_version.mjs",
    "pipeline:hf": "npm run pipeline:export && python3 data-pipeline/import_huggingface.py",
    "pipeline:cocktaildb": "npm run pipeline:export && python3 data-pipeline/import_cocktaildb.py",
    "pipeline": "npm run pipeline:export && npm run pipeline:build && npm run pipeline:version",
    "cap:sync": "npm run build && cap sync",
    "android:open": "cap open android"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^8.1.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sql.js": "^1.14.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^6.0.1",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
