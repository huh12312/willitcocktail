# Phase 5 — cold-start DB sync.
# Set to the GitHub Pages snapshots directory for your deployment.
# Omit (or leave blank) to disable update checks — the bundled cocktails.db
# is always used as a zero-config fallback.
#
# After enabling GitHub Pages (repo Settings → Pages → Source: GitHub Actions),
# the URL is:
#   https://<owner>.github.io/<repo>/snapshots
#
VITE_SNAPSHOT_URL=https://huh12312.github.io/willitcocktail/snapshots
